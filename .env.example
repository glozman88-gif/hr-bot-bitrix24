# Окружение HR-бота. Скопируйте в .env и подставьте реальные значения
# (реальные ключи — в отдельном защищённом сообщении, НЕ в публичном репозитории).

# Персональный API-ключ VibeCode (vibe_api_...). Backend: бот, CRM, AI Router.
VIBE_API_KEY=vibe_api_xxx

# OAuth-приложение (встраивание админки как placement в Битрикс24)
VIBE_APP_KEY=vibe_app_local_xxx
APP_ID=00000000-0000-0000-0000-000000000000

# Публичный адрес приложения (Black Hole subdomain)
APP_URL=https://app-xxxxxxxx.vibecode.bitrix24.tech

# ID зарегистрированного бота (imbot)
BOT_ID=00000

# ID infra-сервера VibeCode (для predeploy-sync.sh)
SERVER_ID=6680c024-3a3e-4821-a898-d90cbefd5ff9

# PostgreSQL (создаётся setup-db.sh в preStart)
DATABASE_URL=postgres://hrbot:hrbotpass@127.0.0.1:5432/hrbot

# Ops-токен для прямого доступа к admin API в обход BFF (для отладки)
ADMIN_API_TOKEN=change-me

# Bitrix24 user id администратора биллинга (видит админ-панель)
ADMIN_USER_ID=154

# Ключи Авито (Профиль → Настройки → API в кабинете Авито)
AVITO_CLIENT_ID=xxx
AVITO_CLIENT_SECRET=xxx

# (Опционально, для будущей сверки оплат) T-Bank Business OpenAPI
# TBANK_TOKEN=xxx
# TBANK_ACCOUNT=40802810900001368970

NODE_ENV=production
